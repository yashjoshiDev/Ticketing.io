# Same as .env but safe to commit — no secrets, only documentation
# Copy to .env and fill in real values.

MONGO_URI_AUTH=mongodb://mongo:27017/auth
MONGO_URI_TICKETS=mongodb://mongo:27017/tickets
MONGO_URI_ORDERS=mongodb://mongo:27017/orders
NATS_SERVERS=nats://nats:4222
JWT_SECRET=REPLACE_ME
